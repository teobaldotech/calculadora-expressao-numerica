<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Resolvedor de Expressão Numérica</title>

<style>
    body{
        font-family: Arial, Helvetica, sans-serif;
        background:#0f172a;
        color:#fff;
        display:flex;
        justify-content:center;
        align-items:center;
        height:100vh;
        margin:0;
    }
    .box{
        background:#1e293b;
        padding:25px;
        border-radius:12px;
        width:95%;
        max-width:420px;
        box-shadow:0 0 20px #000;
        text-align:center;
    }
    h1{
        margin-bottom:15px;
        font-size:22px;
    }
    input{
        width:100%;
        padding:12px;
        font-size:18px;
        border-radius:8px;
        border:none;
        outline:none;
        margin-bottom:15px;
    }
    button{
        width:100%;
        padding:12px;
        font-size:18px;
        border:none;
        border-radius:8px;
        background:#22c55e;
        color:#000;
        cursor:pointer;
        font-weight:bold;
    }
    button:hover{
        background:#16a34a;
    }
    #resultado{
        margin-top:20px;
        font-size:20px;
        font-weight:bold;
        color:#38bdf8;
        min-height:28px;
    }
</style>
</head>
<body>

<div class="box">
    <h1>Expressão Numérica</h1>
    <input type="text" id="expr" placeholder="Ex: (5+3)*2^3-10/2">
    <button onclick="resolver()">Calcular</button>
    <div id="resultado"></div>
</div>

<script>
function resolver(){
    let expr = document.getElementById("expr").value;

    // troca ^ por ** para potência
    expr = expr.replace(/\^/g, "**");

    try{
        // valida caracteres permitidos
        if(!/^[0-9+\-*/().\s*]+$/.test(expr)){
            throw "Expressão inválida!";
        }

        let resultado = Function('"use strict"; return (' + expr + ')')();
        document.getElementById("resultado").innerText = "Resultado: " + resultado;
    }catch(e){
        document.getElementById("resultado").innerText = "Erro na expressão!";
    }
}
</script>

</body>
</html>